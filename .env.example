# Optional HTTP settings
NERAJOB_USER_AGENT=NeraJob/0.1 (+https://github.com/mergeos-bounties/NeraJob)
NERAJOB_HTTP_TIMEOUT=20
NERAJOB_DATA_DIR=data

# Adzuna Jobs API — free keys at https://developer.adzuna.com/
